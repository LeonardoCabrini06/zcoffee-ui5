<mvc:View
    controllerName="zcoffee.controller.ViewProducts"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:smartFilterBar="sap.ui.comp.smartfilterbar"
    xmlns:smartTable="sap.ui.comp.smarttable"
    xmlns:core="sap.ui.core"
    xmlns:customData="http://schemas.sap.com/sapui5/extension/sap.ui.core.CustomData/1"
    height="100%"
>
    <Page
        id="pageProducts"
        title="{i18n>productsTitle}"
        navButtonPress="onNavBack"
        showNavButton="true"
    >
        <content>
            <VBox
                fitContainer="true"
                class="sapUiResponsiveMargin"
            >
                <!-- SmartFilterBar -->
                <smartFilterBar:SmartFilterBar
                    id="smartFilterBar"
                    entitySet="ZCDS_PRODUTOS"
                    persistencyKey="PKey_ProductsFilter"
                    liveMode="true"
                    class="sapUiResponsiveContentPadding"
                >
                    <smartFilterBar:controlConfiguration>
                        <!-- Filtro por Nome -->
                        <smartFilterBar:ControlConfiguration
                            key="Nome"
                            index="0"
                            visibleInAdvancedArea="true"
                            preventInitialDataFetchInValueHelpDialog="true"
                        />

                        <!-- Filtro por Categoria -->
                        <smartFilterBar:ControlConfiguration
                            key="Categoria"
                            index="1"
                            visibleInAdvancedArea="true"
                            preventInitialDataFetchInValueHelpDialog="true"
                        />

                        <!-- Filtro por Status -->
                        <smartFilterBar:ControlConfiguration
                            key="Status"
                            index="2"
                            visibleInAdvancedArea="true"
                            preventInitialDataFetchInValueHelpDialog="true"
                        />
                    </smartFilterBar:controlConfiguration>

                    <smartFilterBar:layoutData>
                        <FlexItemData shrinkFactor="0" />
                    </smartFilterBar:layoutData>
                </smartFilterBar:SmartFilterBar>

                <!-- SmartTable -->
                <smartTable:SmartTable
                    id="ListProducts"
                    entitySet="ZCDS_PRODUTOS"
                    smartFilterId="smartFilterBar"
                    tableType="ResponsiveTable"
                    useVariantManagement="true"
                    useTablePersonalisation="true"
                    header="{i18n>productsTitle}"
                    showRowCount="true"
                    enableAutoBinding="true"
                    enableAutoColumnWidth="false"
                    persistencyKey="PKey_ProductsTable"
                    class="sapUiResponsiveContentPadding"
                    initiallyVisibleFields="ImagemURL,IdProduto,Nome,Preco,Validade,Status,Categoria"
                    width="100%"
                    requestAtLeastFields="Moeda"
                >
                    <!-- Toolbar com os botões CRUD -->
                    <smartTable:customToolbar>
                        <OverflowToolbar
                            id="customToolbar"
                            width="100%"
                        >
                            <ToolbarSpacer />

                            <!-- Botão Adicionar -->
                            <OverflowToolbarButton
                                id="btn_add"
                                icon="sap-icon://add"
                                text="Adicionar"
                                press="onAddProduct"
                                tooltip="Adicionar novo produto"
                                type="Emphasized"
                            />

                            <ToolbarSeparator />
                        </OverflowToolbar>
                    </smartTable:customToolbar>

                    <!-- Sap.m.Table -->
                    <Table
                        id="CustomColumnsTable"
                        mode="Delete"
                        itemPress="onItemPress"
                        delete="onDeleteProduct"
                        width="100%"
                        selectionChange="onTableSelectionChange"
                    >
                        <columns>
                            <!-- Foto do Produto -->
                            <Column
                                id="imgColumn"
                                width="60px"
                                hAlign="Center"
                            >
                                <customData>
                                    <core:CustomData
                                        key="p13nData"
                                        value='\{"columnKey": "ImagemURL", "leadingProperty": "ImagemURL", "columnIndex": 0\}'
                                    />
                                </customData>
                                <Text text="Foto" />
                            </Column>

                            <!-- Coluna: ID do Produto -->
                            <Column
                                id="idColumn"
                                width="80px"
                                hAlign="Center"
                            >
                                <customData>
                                    <core:CustomData
                                        key="p13nData"
                                        value='\{"columnKey": "IdProduto", "leadingProperty": "IdProduto", "columnIndex": 1\}'
                                    />
                                </customData>
                                <Text text="ID" />
                            </Column>

                            <!-- Coluna: Nome do Produto -->
                            <Column
                                id="nomeColumn"
                                width="220px"
                            >
                                <customData>
                                    <core:CustomData
                                        key="p13nData"
                                        value='\{"columnKey": "Nome", "leadingProperty": "Nome", "columnIndex": 2\}'
                                    />
                                </customData>
                                <Text text="Nome do Produto" />
                            </Column>

                            <!-- Coluna: Preço (alinhado à direita) -->
                            <Column
                                id="PrecoColumn"
                                width="100px"
                                hAlign="End"
                            >
                                <customData>
                                    <core:CustomData
                                        key="p13nData"
                                        value='\{"columnKey": "Preco", "leadingProperty": "Preco", "columnIndex": 3\}'
                                    />
                                </customData>
                                <Text text="Preço" />
                            </Column>

                            <!-- Coluna: Data de Validade -->
                            <Column
                                id="validadeColumn"
                                width="100px"
                                hAlign="Center"
                            >
                                <customData>
                                    <core:CustomData
                                        key="p13nData"
                                        value='\{"columnKey": "Validade", "leadingProperty": "Validade", "columnIndex": 4\}'
                                    />
                                </customData>
                                <Text text="Validade" />
                            </Column>

                            <!-- Coluna: Status (Ativo/Inativo) -->
                            <Column
                                id="statusColumn"
                                width="100px"
                                hAlign="Center"
                            >
                                <customData>
                                    <core:CustomData
                                        key="p13nData"
                                        value='\{"columnKey": "Status", "leadingProperty": "Status", "columnIndex": 5\}'
                                    />
                                </customData>
                                <Text text="Status" />
                            </Column>

                            <!-- Coluna: Categoria do Produto -->
                            <Column
                                id="CategoriaColumn"
                                width="130px"
                                hAlign="Center"
                            >
                                <customData>
                                    <core:CustomData
                                        key="p13nData"
                                        value='\{"columnKey": "Categoria", "leadingProperty": "Categoria", "columnIndex": 6\}'
                                    />
                                </customData>
                                <Text text="Categoria" />
                            </Column>
                        </columns>

                        <items>
                            <ColumnListItem
                                type="Detail"
                                detailPress="onProductEdit"
                            >
                                <cells>
                                    <Image
                                        src="{ImagemURL}"
                                        width="40px"
                                        height="40px"
                                        densityAware="false"
                                        alt="{Nome}"
                                    />

                                    <Text text="{IdProduto}" />
                                    <Text text="{Nome}" />
                                    <ObjectNumber
                                        number="{ parts: [ {path: 'Preco'}, {path: 'Moeda'} ], type: 'sap.ui.model.type.Currency', formatOptions: { showMeasure: true } }"
                                    />
                                    <Text
                                        text="{ path: 'Validade', 
                                        type: 'sap.ui.model.type.Date', formatOptions: { pattern: 'dd/MM/yyyy' } }"
                                    />
                                    <ObjectStatus
                                        text="{ path: 'Status', formatter: '.formatter.formatStatus' }"
                                        state="{ path: 'Status', formatter: '.formatter.formatStatusState' }"
                                        inverted="true"
                                    />

                                    <!-- Célula 6: Categoria -->
                                    <ObjectStatus
                                        text="{ path: 'Categoria', formatter: '.formatter.formatCategoria' }"
                                        inverted="false"
                                    />
                                </cells>
                            </ColumnListItem>
                        </items>
                    </Table>

                    <smartTable:layoutData>
                        <FlexItemData
                            growFactor="1"
                            baseSize="0%"
                        />
                    </smartTable:layoutData>
                </smartTable:SmartTable>
            </VBox>
        </content>
    </Page>
</mvc:View>
