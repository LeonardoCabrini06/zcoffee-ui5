<mvc:View controllerName="zcoffee.controller.ViewRH"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:fb="sap.ui.comp.filterbar"
    xmlns:layout="sap.ui.layout">

    <Page id="page_RH" title="{i18n>title}">

        <VBox
            width="100%"
            alignItems="Center"
            justifyContent="Start"
            class="sapUiMediumMarginTop">

            <Table
                id="TableRH"
                items="{/ZIRH_ZCOFFEE}"
                mode="Delete"
                delete="onDelete"
                width="90%"
                inset="false"
                autoPopinMode="true"
                class="sapUiResponsiveMargin">

               <headerToolbar>
                    <OverflowToolbar>

                        <Title text="Funcionários" />

                        <ToolbarSpacer />

                        <SearchField
                            id="searchFuncionario"
                            width="15rem"
                            placeholder="Buscar funcionário"
                            liveChange="onSearch" />

                        <MultiComboBox
                            id="mcCargo"
                            width="12rem"
                            placeholder="Cargo"
                            selectionFinish="onFilterToolbar">

                            <items>
                                <core:Item key="1" text="Atendente" />
                                <core:Item key="2" text="Barista" />
                                <core:Item key="3" text="Garçom" />
                                <core:Item key="4" text="Gerente" />
                                <core:Item key="5" text="Cozinheiro" />
                            </items>

                        </MultiComboBox>

                        <MultiComboBox
                            id="mcStatus"
                            width="12rem"
                            placeholder="Status"
                            selectedKeys="A"
                            selectionFinish="onFilterToolbar">

                            <items>
                                <core:Item key="A" text="Ativo" />
                                <core:Item key="I" text="Inativo" />
                            </items>

                        </MultiComboBox>

                        <DateRangeSelection
                            id="drsAdmissao"
                            width="14rem"
                            displayFormat="dd/MM/yyyy"
                            change="onFilterToolbar" />

                        <Button
                            icon="sap-icon://clear-filter"
                            tooltip="Limpar filtros"
                            press="onClearFilters" />

                        <Button
                            icon="sap-icon://refresh"
                            tooltip="Atualizar"
                            press="onRefresh" />

                        <Button
                            text="Novo Funcionário"
                            icon="sap-icon://add"
                            type="Emphasized"
                            press="onNovoFuncionario" />

                    </OverflowToolbar>

                </headerToolbar>

                <columns>
                    <Column>
                        <Text text="ID"></Text>
                    </Column>
                    <Column>
                        <Text text="Nome"></Text>
                    </Column>
                    <Column>
                        <Text text="CPF"></Text>
                    </Column>
                    <Column>
                        <Text text="Email"></Text>
                    </Column>
                    <Column>
                        <Text text="Telefone"></Text>
                    </Column>
                    <Column>
                        <Text text="Nascimento"></Text>
                    </Column>
                    <Column>
                        <Text text="Admissao"></Text>
                    </Column>
                    <Column>
                        <Text text="Cargo"></Text>
                    </Column>
                    <Column>
                        <Text text="Salario"></Text>
                    </Column>
                    <Column>
                        <Text text="Status"></Text>
                    </Column>
                    <Column>
                        <Text text="Login"></Text>
                    </Column>
                </columns>
                <items>
                    <ColumnListItem type="Detail" detailPress="onEditFuncionario">
                        <cells>
                            <ObjectIdentifier title="{ID}"></ObjectIdentifier>
                            <Text text="{Nome}"></Text>

                            <Text text="{CPF}"></Text>
                            <Text text="{Email}"></Text>
                            <Text text="{Telefone}"></Text>

                            <Text text="{
                                path: 'Nascimento',
                                type: 'sap.ui.model.odata.type.DateTime',
                                formatOptions: {
                                    UTC: false,
                                    pattern: 'dd/MM/yyyy'
                                }
                            }" />

                            <Text text="{
                                path: 'Admissao',
                                type: 'sap.ui.model.type.DateTime',
                                formatOptions: {
                                    UTC: false,
                                    pattern: 'dd/MM/yyyy'
                                }
                            }" />

                            <Text text="{
                                path: 'Cargo',
                                formatter: '.formatter.formatCargo'
                            }" />

                            <ObjectNumber
                                number="{Salario}"
                                unit="{Moeda}" />

                           <ObjectStatus 
                                text="{
                                    path: 'Status',
                                    formatter: '.formatter.formatStatus'
                                }"
                                state="{
                                    path: 'Status',
                                    formatter: '.formatter.formatStatusState'
                                }" />
                                
                            <Text text="{Login}"></Text>
                        </cells>
                    </ColumnListItem>
                </items>
        
            </Table>
        </VBox>

    </Page>
</mvc:View>